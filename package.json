{
  "name": "finance-formulas",
  "version": "1.7.0",
  "description": "Simple finance calculation utilities",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./sip": {
      "import": "./dist/calculators/sip.js",
      "require": "./dist/calculators/sip.cjs",
      "types": "./dist/calculators/sip.d.ts"
    },
    "./emi": {
      "import": "./dist/calculators/emi.js",
      "require": "./dist/calculators/emi.cjs",
      "types": "./dist/calculators/emi.d.ts"
    },
    "./fd": {
      "import": "./dist/calculators/fd.js",
      "require": "./dist/calculators/fd.cjs",
      "types": "./dist/calculators/fd.d.ts"
    },
    "./cagr": {
      "import": "./dist/calculators/cagr.js",
      "require": "./dist/calculators/cagr.cjs",
      "types": "./dist/calculators/cagr.d.ts"
    },
    "./total-interest": {
      "import": "./dist/calculators/totalInterest.js",
      "require": "./dist/calculators/totalInterest.cjs",
      "types": "./dist/calculators/totalInterest.d.ts"
    },
    "./time-to-double": {
      "import": "./dist/calculators/timeToDouble.js",
      "require": "./dist/calculators/timeToDouble.cjs",
      "types": "./dist/calculators/timeToDouble.d.ts"
    },
    "./future-value": {
      "import": "./dist/calculators/futureValue.js",
      "require": "./dist/calculators/futureValue.cjs",
      "types": "./dist/calculators/futureValue.d.ts"
    },
    "./present-value": {
      "import": "./dist/calculators/presentValue.js",
      "require": "./dist/calculators/presentValue.cjs",
      "types": "./dist/calculators/presentValue.d.ts"
    },
    "./variable-return": {
      "import": "./dist/calculators/variableReturn.js",
      "require": "./dist/calculators/variableReturn.cjs",
      "types": "./dist/calculators/variableReturn.d.ts"
    },
    "./swp": {
      "import": "./dist/calculators/swp.js",
      "require": "./dist/calculators/swp.cjs",
      "types": "./dist/calculators/swp.d.ts"
    }
  },
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "npm run build:bundle && npm run build:split && npm run build:types",
    "build:bundle": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js && esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/index.cjs",
    "build:split": "esbuild src/calculators/sip.ts src/calculators/emi.ts src/calculators/fd.ts src/calculators/cagr.ts src/calculators/totalInterest.ts src/calculators/timeToDouble.ts src/calculators/futureValue.ts src/calculators/presentValue.ts src/calculators/variableReturn.ts src/calculators/swp.ts --format=esm --outdir=dist/calculators && esbuild src/calculators/sip.ts src/calculators/emi.ts src/calculators/fd.ts src/calculators/cagr.ts src/calculators/totalInterest.ts src/calculators/timeToDouble.ts src/calculators/futureValue.ts src/calculators/presentValue.ts src/calculators/variableReturn.ts src/calculators/swp.ts --format=cjs --outdir=dist/calculators --out-extension:.js=.cjs",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "docs": "typedoc",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "finance",
    "financial",
    "calculator",
    "interest",
    "investment",
    "sip",
    "systematic-investment-plan",
    "emi",
    "equated-monthly-installment",
    "loan",
    "fd",
    "fixed-deposit",
    "cagr",
    "compound-annual-growth-rate",
    "lump-sum",
    "future-value",
    "present-value",
    "variable-returns",
    "volatile-returns",
    "real-world-compounding",
    "discounting",
    "compound-interest",
    "retirement",
    "swp",
    "systematic-withdrawal-plan",
    "fire",
    "typescript",
    "javascript",
    "utilities",
    "math",
    "formulas"
  ],
  "author": "Chandrakant <chandrakantsavvy@gmail.com> (https://github.com/bechandrakant)",
  "repository": {
    "type": "git",
    "url": "https://github.com/bechandrakant/finance-formulas.git"
  },
  "homepage": "https://github.com/bechandrakant/finance-formulas#readme",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.19.0",
    "jest": "^29.5.0",
    "semantic-release": "^25.0.3",
    "ts-jest": "^29.1.0",
    "typedoc": "^0.28.19",
    "typescript": "^5.0.0"
  }
}
