{
  "name": "finance-formulas",
  "version": "0.0.0-development",
  "description": "Simple finance calculation utilities",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "exports": {
    "import": "./dist/index.js",
    "require": "./dist/index.cjs"
  },
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs",
    "build:esm": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js",
    "build:cjs": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/index.cjs",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "finance",
    "financial",
    "calculator",
    "interest",
    "investment",
    "sip",
    "systematic-investment-plan",
    "emi",
    "equated-monthly-installment",
    "loan",
    "fd",
    "fixed-deposit",
    "cagr",
    "compound-annual-growth-rate",
    "typescript",
    "javascript",
    "utilities",
    "math",
    "formulas"
  ],
  "author": "Chandrakant <chandrakantsavvy@gmail.com> (https://github.com/bechandrakant)",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.19.0",
    "jest": "^29.5.0",
    "semantic-release": "^25.0.3",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  }
}
